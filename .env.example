# Browser / Vite (required for the site). Copy to `.env` locally.
# Production: set the same names in your host (e.g. Vercel → Environment Variables) and redeploy.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Firebase Admin SDK for migrations (thumbnail backfill script).
# 1. Firebase Console → Project settings → Service accounts → Generate new private key.
# 2. Save JSON as ".secrets/firebase-admin.json" (folder is gitignored).
#    Do not commit the key file.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/firebase-admin.json
